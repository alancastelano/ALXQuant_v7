{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "permission": "allow",
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "environment": {
        "MEMORY_FILE_PATH": "C:\\ALXQuant_v7\\.memory.json"
      }
    },
    "fred": {
      "type": "local",
      "command": ["node", "C:\\Users\\User\\AppData\\Roaming\\npm\\node_modules\\fred-mcp-server\\build\\wrapper.mjs"],
      "enabled": true,
      "environment": {
        "FRED_API_KEY": "83c3a6c61a22d793c4fa63e5cdda9843"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "postgresql://mcp_readonly:mcp_readonly@localhost:5432/alxquant?sslmode=disable"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--executable-path", "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe"],
      "enabled": true
    }
  }
}
